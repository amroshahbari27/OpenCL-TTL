} TTL_duplex_const_ushort_tensor_buffering_t;




static inline TTL_io_ushort_tensor_t __attribute__((overloadable))
TTL_step_buffering(TTL_duplex_const_ushort_tensor_buffering_t *const duplex_buffering, TTL_tile_t tile_next_import, TTL_tile_t tile_current_export);
