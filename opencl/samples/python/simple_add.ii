# 26 "./compute_cross.h"
void compute(TTL_int_int_sub_tensor_t tensor_in,
             TTL_int_int_sub_tensor_t tensor_out) {
    for (int y = 0; y < tensor_out.tensor.shape.height; ++y) {
        for (int x = 0; x < tensor_out.tensor.shape.width; ++x) {
            const int x_in = x + 10;
            const int y_in = y + 10;
            const int left = TTL_read_tensor(tensor_in, x_in - 1, y_in);
            const int above = TTL_read_tensor(tensor_in, x_in, y_in - 1);
            const int centre = TTL_read_tensor(tensor_in, x_in, y_in);
            const int right = TTL_read_tensor(tensor_in, x_in + 1, y_in);
            const int bottom = TTL_read_tensor(tensor_in, x_in, y_in + 1);

            TTL_write_tensor(tensor_out, left + above + centre + right + bottom, x, y);
        }
    }
}
# 3 "simple_add.cl" 2
# 12 "simple_add.cl"
__kernel void simple_add(__global int *restrict ext_base_A, int external_stride_A,
                        __global int *restrict ext_base_B, int external_stride_B,
                        __global int *restrict ext_base_C, int external_stride_C,
                        int width, int height) {

    const TTL_shape_t tensor_shape = TTL_create_shape(width, height);
    const TTL_layout_t ext_layout_A = TTL_create_layout(external_stride_A);
    const TTL_layout_t ext_layout_B = TTL_create_layout(external_stride_B);
    const TTL_layout_t ext_layout_C = TTL_create_layout(external_stride_C);


    const TTL_ext_int_tensor_t ext_tensor_A = TTL_create_ext_tensor(ext_base_A, tensor_shape, ext_layout_A);
    const TTL_ext_int_tensor_t ext_tensor_B = TTL_create_ext_tensor(ext_base_B, tensor_shape, ext_layout_B);
    const TTL_ext_int_tensor_t ext_tensor_C = TTL_create_ext_tensor(ext_base_C, tensor_shape, ext_layout_C);

    for (int y = 0; y < height; y += 1) for (int x = 0; x < width; x += 1) {
        TTL_offset_t offset = TTL_create_offset(x, y, 0);
        int idx_A = TTL_linearize(offset, ext_layout_A);
        int idx_B = TTL_linearize(offset, ext_layout_B);
        int idx_C = TTL_linearize(offset, ext_layout_C);
        ext_base_C[idx_C] = ext_base_A[idx_A] + ext_base_B[idx_B];
    }
}
