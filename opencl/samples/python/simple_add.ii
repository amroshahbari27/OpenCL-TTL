static inline void __TTL_dump_event(const TTL_event_t* const ttl_event) {

    const unsigned char* const event = *(const unsigned char**)ttl_event;

    if (!event) {
        printf("event=NULL");
    } else {
        printf("event=%p (channels mask=0x%x)", event, *event);
    }
}
